# ==========================================
# TESTMO DASHBOARD - Configuration Backend
# ==========================================
# ⚠️ IMPORTANT: Copier ce fichier en .env et remplir les valeurs réelles
# ⚠️ NE JAMAIS COMMITER le fichier .env dans Git !

# Configuration Testmo API
TESTMO_URL=https://votre-instance.testmo.net
TESTMO_TOKEN=testmo_api_VOTRE_TOKEN_ICI

# Configuration serveur
PORT=3001
NODE_ENV=development

# CORS - Autoriser le frontend
FRONTEND_URL=http://localhost:3000

# Cache & Performance (LEAN principles)
CACHE_DURATION=30000
API_TIMEOUT=10000

# Logging (ITIL Service Management)
LOG_LEVEL=info

# ==========================================
# Configuration GitLab API (Sync)
# ==========================================
GITLAB_URL=https://gitlab.neo-logix.fr
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_PROJECT_ID=63
GITLAB_LABEL=test::TODO
GITLAB_VERIFY_SSL=false

# ==========================================
# Sync GitLab → Testmo
# ==========================================
TESTMO_PROJECT_ID=1
TESTMO_REPOSITORY_ID=1
TESTMO_ROOT_GROUP_ID=4514

# ==========================================
# INSTRUCTIONS DE GÉNÉRATION DES TOKENS:
# ==========================================
# Testmo:
# 1. Se connecter à Testmo
# 2. Cliquer sur l'avatar (coin supérieur droit)
# 3. User Profile > API access
# 4. Generate new API key
# 5. Copier le token (affiché une seule fois!)
# 6. Coller dans TESTMO_TOKEN ci-dessus
#
# GitLab:
# 1. Se connecter à GitLab
# 2. User Settings > Access Tokens
# 3. Créer un token avec scope: read_api
# 4. Coller dans GITLAB_TOKEN ci-dessus
